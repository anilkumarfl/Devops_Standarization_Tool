# Observability — CloudWatch logs and alarms (aws provider ~> 6.0)
# Retention: {{ log_retention.dev }}d dev / {{ log_retention.staging }}d staging / {{ log_retention.prod }}d prod

locals {
  log_retention_days = {
    dev     = {{ log_retention.dev }}
    staging = {{ log_retention.staging }}
    prod    = {{ log_retention.prod }}
  }
}

{% if 'cloudwatch' not in services %}
# Application log group — used by compute templates via local.log_retention_days
resource "aws_cloudwatch_log_group" "app" {
  name              = "/app/{{ project_name }}-${var.environment}"
  retention_in_days = lookup(local.log_retention_days, var.environment, 30)
  kms_key_id        = try(aws_kms_key.main.arn, null)

  tags = {
    Name        = "{{ project_name }}-${var.environment}-app-logs"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}
{% endif %}

{% if 'cloudwatch' not in services and 'lambda' in compute_target %}
# Lambda error-rate alarm
resource "aws_cloudwatch_metric_alarm" "lambda_errors" {
  alarm_name          = "{{ project_name }}-${var.environment}-lambda-errors"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 2
  datapoints_to_alarm = 2
  metric_name         = "Errors"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 5
  treat_missing_data  = "notBreaching"
  alarm_description   = "Lambda error count exceeded 5 in 2 consecutive 1-min windows"

  dimensions = {
    FunctionName = "{{ project_name }}-${var.environment}-func"
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-lambda-errors"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

# Lambda throttle alarm
resource "aws_cloudwatch_metric_alarm" "lambda_throttles" {
  alarm_name          = "{{ project_name }}-${var.environment}-lambda-throttles"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 2
  datapoints_to_alarm = 2
  metric_name         = "Throttles"
  namespace           = "AWS/Lambda"
  period              = 60
  statistic           = "Sum"
  threshold           = 10
  treat_missing_data  = "notBreaching"
  alarm_description   = "Lambda throttle count exceeded 10 — consider reserved concurrency"

  dimensions = {
    FunctionName = "{{ project_name }}-${var.environment}-func"
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-lambda-throttles"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

# Lambda P99 duration alarm
resource "aws_cloudwatch_metric_alarm" "lambda_duration" {
  alarm_name          = "{{ project_name }}-${var.environment}-lambda-duration-p99"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 3
  datapoints_to_alarm = 2
  metric_name         = "Duration"
  namespace           = "AWS/Lambda"
  period              = 300
  extended_statistic  = "p99"
  threshold           = 25000   # 25 seconds — alert before 30s timeout
  treat_missing_data  = "notBreaching"
  alarm_description   = "Lambda p99 duration approaching timeout"

  dimensions = {
    FunctionName = "{{ project_name }}-${var.environment}-func"
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-lambda-duration"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}
{% endif %}
{% if 'cloudwatch' not in services and ('ecs-fargate' in compute_target or 'eks' in services) %}
# ECS/EKS CPU alarm
resource "aws_cloudwatch_metric_alarm" "cpu_high" {
  alarm_name          = "{{ project_name }}-${var.environment}-cpu-high"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 3
  datapoints_to_alarm = 2
  metric_name         = "CPUUtilization"
  namespace           = "AWS/ECS"
  period              = 60
  statistic           = "Average"
  threshold           = 80
  treat_missing_data  = "notBreaching"
  alarm_description   = "CPU utilization above 80% for 3 consecutive minutes"

  dimensions = {
    ClusterName = "{{ project_name }}-${var.environment}-ecs"
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-cpu-high"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}
{% endif %}
{% if 'cloudwatch' not in services and 'api-gateway' in services %}
# API Gateway 5xx error alarm
resource "aws_cloudwatch_metric_alarm" "api_5xx" {
  alarm_name          = "{{ project_name }}-${var.environment}-api-5xx"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 2
  datapoints_to_alarm = 2
  metric_name         = "5XXError"
  namespace           = "AWS/ApiGateway"
  period              = 60
  statistic           = "Sum"
  threshold           = 10
  treat_missing_data  = "notBreaching"
  alarm_description   = "API Gateway 5xx errors exceeded threshold"

  dimensions = {
    ApiId = aws_apigatewayv2_api.main.id
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-api-5xx"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}
{% endif %}
{% if 'cloudwatch' not in services and 'sqs' in services %}
# SQS DLQ depth alarm — messages in DLQ means processing failures need attention
resource "aws_cloudwatch_metric_alarm" "dlq_depth" {
  alarm_name          = "{{ project_name }}-${var.environment}-dlq-depth"
  comparison_operator = "GreaterThanThreshold"
  evaluation_periods  = 1
  datapoints_to_alarm = 1
  metric_name         = "ApproximateNumberOfMessagesVisible"
  namespace           = "AWS/SQS"
  period              = 60
  statistic           = "Sum"
  threshold           = 0
  treat_missing_data  = "notBreaching"
  alarm_description   = "Messages present in DLQ — investigate processing failures"

  dimensions = {
    QueueName = aws_sqs_queue.dlq.name
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-dlq-depth"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}
{% endif %}
