{% if 'lambda' in compute_target and 'eks' not in services and 'ecs-fargate' not in services and 'static-site' in services and 'alb' not in services %}
# No VPC required for this architecture — Lambda functions access
# AWS managed services (DynamoDB, S3, SQS, Bedrock) via service endpoints.
# CloudFront -> S3 traffic stays within the AWS network.
{% else %}
# VPC — all compute runs inside a multi-AZ VPC (aws provider ~> 6.0)
data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_vpc" "main" {
  cidr_block           = "{{ vpc_cidr }}"
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Name        = "{{ project_name }}-${var.environment}-vpc"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

# Public subnets — NAT gateways and load balancers only
resource "aws_subnet" "public" {
  count             = 2
  vpc_id            = aws_vpc.main.id
  cidr_block        = cidrsubnet(aws_vpc.main.cidr_block, 8, count.index)
  availability_zone = data.aws_availability_zones.available.names[count.index]

  # Do NOT assign public IPs to instances — use NAT for egress
  map_public_ip_on_launch = false

  tags = {
    Name        = "{{ project_name }}-${var.environment}-pub-${count.index + 1}"
    Environment = var.environment
    CostCentre  = var.cost_centre
    # EKS subnet auto-discovery tags
    "kubernetes.io/role/elb" = "1"
  }
}

# Private subnets — compute, databases, and internal services
resource "aws_subnet" "private" {
  count             = 2
  vpc_id            = aws_vpc.main.id
  cidr_block        = cidrsubnet(aws_vpc.main.cidr_block, 8, count.index + 10)
  availability_zone = data.aws_availability_zones.available.names[count.index]

  tags = {
    Name        = "{{ project_name }}-${var.environment}-priv-${count.index + 1}"
    Environment = var.environment
    CostCentre  = var.cost_centre
    # EKS subnet auto-discovery tags
    "kubernetes.io/role/internal-elb" = "1"
  }
}

# Internet Gateway — provides outbound internet for public subnets
resource "aws_internet_gateway" "main" {
  vpc_id = aws_vpc.main.id

  tags = {
    Name        = "{{ project_name }}-${var.environment}-igw"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

# Elastic IP for NAT Gateway
resource "aws_eip" "nat" {
  domain     = "vpc"
  depends_on = [aws_internet_gateway.main]

  tags = {
    Name        = "{{ project_name }}-${var.environment}-nat-eip"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

# NAT Gateway — allows private subnet instances to reach the internet
resource "aws_nat_gateway" "main" {
  allocation_id = aws_eip.nat.id
  subnet_id     = aws_subnet.public[0].id

  tags = {
    Name        = "{{ project_name }}-${var.environment}-nat"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }

  depends_on = [aws_internet_gateway.main]
}

# Public route table — routes internet traffic via IGW
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.main.id
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-rt-public"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

resource "aws_route_table_association" "public" {
  count          = 2
  subnet_id      = aws_subnet.public[count.index].id
  route_table_id = aws_route_table.public.id
}

# Private route table — routes egress traffic via NAT Gateway
resource "aws_route_table" "private" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.main.id
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-rt-private"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

resource "aws_route_table_association" "private" {
  count          = 2
  subnet_id      = aws_subnet.private[count.index].id
  route_table_id = aws_route_table.private.id
}

# Security group — deny-all default; explicit ingress added by compute templates
resource "aws_security_group" "app" {
  name        = "{{ project_name }}-${var.environment}-sg"
  description = "Application security group — explicit allow-list only"
  vpc_id      = aws_vpc.main.id

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow all outbound traffic"
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-sg"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}
{% endif %}
