# KMS — customer-managed encryption key (aws provider ~> 6.0)
resource "aws_kms_key" "main" {
  description             = "{{ project_name }}-${var.environment} CMK"
  deletion_window_in_days = var.environment == "prod" ? 30 : 7
  enable_key_rotation     = true
  key_usage               = "ENCRYPT_DECRYPT"
  multi_region            = false   # set true only if cross-region replication needed

  tags = {
    Name        = "{{ project_name }}-${var.environment}-kms"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

resource "aws_kms_alias" "main" {
  name          = "alias/{{ project_name }}-${var.environment}"
  target_key_id = aws_kms_key.main.key_id
}

output "kms_key_arn" {
  description = "CMK ARN used for encryption across all services"
  value       = aws_kms_key.main.arn
}
