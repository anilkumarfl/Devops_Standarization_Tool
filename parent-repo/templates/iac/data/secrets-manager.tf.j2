# Secrets Manager — runtime credentials store (aws provider ~> 6.0)
# Stores kubeconfig / EKS auth tokens that Lambda reads at deploy time.

resource "aws_secretsmanager_secret" "app" {
  name        = "{{ project_name }}/${var.environment}/app"
  description = "Application secrets for {{ project_name }} (${var.environment})"

  {% if 'kms' in services %}
  kms_key_id = aws_kms_key.main.arn
  {% endif %}

  # Allow immediate deletion in non-prod; enforce 30-day recovery window in prod
  recovery_window_in_days = var.environment == "prod" ? 30 : 0

  tags = {
    Name        = "{{ project_name }}-${var.environment}-secrets"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}

{% if 'eks' in services %}
resource "aws_secretsmanager_secret" "eks_auth" {
  name        = "{{ project_name }}/${var.environment}/eks-auth"
  description = "EKS kubeconfig credentials for Lambda deployment function"

  {% if 'kms' in services %}
  kms_key_id = aws_kms_key.main.arn
  {% endif %}

  recovery_window_in_days = var.environment == "prod" ? 30 : 0

  tags = {
    Name        = "{{ project_name }}-${var.environment}-eks-auth"
    Environment = var.environment
    CostCentre  = var.cost_centre
  }
}
{% endif %}

output "secrets_manager_arn" {
  description = "Secrets Manager ARN for app secrets"
  value       = aws_secretsmanager_secret.app.arn
}

{% if 'eks' in services %}
output "eks_auth_secret_arn" {
  description = "Secrets Manager ARN for EKS auth credentials (used by Lambda)"
  value       = aws_secretsmanager_secret.eks_auth.arn
}
{% endif %}
